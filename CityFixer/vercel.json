{
  "rewrites": [
    {
      "source": "/georef/(.*)",
      "destination": "https://apis.datos.gob.ar/georef/api/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://cityfixer-ngbl.onrender.com/api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "https://cityfixer-ngbl.onrender.com/auth/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
